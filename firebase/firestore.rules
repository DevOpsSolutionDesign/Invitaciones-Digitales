rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /paletas/{paletaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /clientes/{clienteId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
